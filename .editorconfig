# Repo-agnostic base — will be superseded by the devopser skeleton when the
# Go variant ships (kept in sync with that plan so the swap is trivial).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab
